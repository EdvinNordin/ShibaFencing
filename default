server {
    server_name game.edvinnordin.me;

    # The root and index aren't strictly necessary when using a proxy, 
    # but it's fine to leave them.
    root /var/www/html;
    index index.html index.htm;

    location /ws {
        proxy_pass http://localhost:8181;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;

        proxy_read_timeout 86400;    
    }

    # 2. Route everything else to the frontend
    location / {
        proxy_pass http://localhost:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    # --- KEEP THE CERTBOT SSL STUFF BELOW ---
    listen [::]:443 ssl ipv6only=on; # managed by Certbot
    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/game.edvinnordin.me/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/game.edvinnordin.me/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}

server {
    if ($host = game.edvinnordin.me) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80 default_server;
    listen [::]:80 default_server;

    server_name game.edvinnordin.me;
    return 404; # managed by Certbot
}
