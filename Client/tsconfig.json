{
    "compilerOptions": {
      "target": "es6",
      "module": "esnext",
      "moduleResolution": "bundler",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "outDir": "./dist",
      "rootDir": "./src",
      "types": ["vite/client"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules"]
  }